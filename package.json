{
  "name": "unit-tests-jest",
  "version": "1.0.0",
  "description": "Example to unit tests using Jest with Stryker mutation testing",
  "main": "index.js",
  "author": "ugioni",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "mkdirp": "^3.0.1",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/jest-runner": "^8.7.1"
  },
  "scripts": {
    "clean": "rimraf ./coverage && mkdirp ./coverage",
    "test": "npm run clean && jest",
    "coverage": "npm run clean && jest --coverage",
    "mutate": "stryker run"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageReporters": [
      "lcov",
      "text"
    ]
  }
}